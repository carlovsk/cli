{
  "name": "quota-cli",
  "version": "1.0.0",
  "description": "A TypeScript CLI tool that checks AI tool quota/usage across multiple providers",
  "main": "lib/index.js",
  "bin": {
    "quota": "./bin/run"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "prepack": "npm run build",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf lib"
  },
  "files": [
    "/bin",
    "/lib",
    "/oclif.manifest.json"
  ],
  "dependencies": {
    "@oclif/core": "^3.15.1",
    "@oclif/plugin-help": "^6.0.9",
    "axios": "^1.6.2",
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "inquirer": "^8.2.6",
    "open": "^8.4.2"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.5",
    "@types/inquirer": "^8.2.10",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "oclif": {
    "bin": "quota",
    "dirname": "quota-cli",
    "commands": "./lib/commands",
    "topicSeparator": " "
  },
  "keywords": [
    "cli",
    "quota",
    "ai",
    "typescript"
  ],
  "author": "Carlos",
  "license": "MIT"
}