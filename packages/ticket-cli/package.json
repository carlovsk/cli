{
  "name": "@cli-tools/ticket-cli",
  "version": "1.0.0",
  "description": "TypeScript CLI tool for managing tickets across Linear, Jira, and GitHub",
  "type": "module",
  "bin": {
    "ticket": "./bin/run.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "clean": "rm -rf lib"
  },
  "keywords": [
    "cli",
    "tickets",
    "linear",
    "jira",
    "github",
    "issues"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "lib/**/*",
    "bin/**/*",
    "oclif.manifest.json"
  ],
  "oclif": {
    "bin": "ticket",
    "dirname": "ticket-cli",
    "commands": "./lib/commands",
    "plugins": [],
    "topicSeparator": " "
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/inquirer": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^8.21.1",
    "@typescript-eslint/parser": "^8.21.1",
    "eslint": "^9.16.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.14"
  },
  "dependencies": {
    "@oclif/core": "^4.0.21",
    "axios": "^1.13.5",
    "graphql-request": "^7.1.4",
    "chalk": "^5.3.0",
    "inquirer": "^11.1.0",
    "cli-table3": "^0.6.5",
    "dayjs": "^1.11.15"
  }
}